<Application x:Class="EW_Assistant.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:EW_Assistant"
             xmlns:svc="clr-namespace:EW_Assistant.Services"
             StartupUri="MainWindow.xaml"
             DispatcherUnhandledException="Application_DispatcherUnhandledException">
    <Application.Resources>
        <FontFamily x:Key="AppFontFamily">{x:Static svc:UiFontService.AppFontFamily}</FontFamily>

        <Style TargetType="{x:Type Control}">
            <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}"/>
        </Style>

        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}"/>
        </Style>

        <Style TargetType="{x:Type Window}">
            <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}"/>
        </Style>

        <Style TargetType="{x:Type Page}">
            <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}"/>
        </Style>

        <Style TargetType="{x:Type UserControl}">
            <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}"/>
        </Style>
    </Application.Resources>
</Application>

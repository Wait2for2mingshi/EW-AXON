<Window x:Class="EW_Assistant.Views.Reports.ReportChartDrilldownWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="图表详情"
        Width="820"
        Height="660"
        MinWidth="720"
        MinHeight="560"
        WindowStartupLocation="CenterOwner"
        Background="#F3F4F6"
        FontFamily="{StaticResource AppFontFamily}"
        FontSize="14">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="14"/>
        </Style>

        <Style x:Key="MetricCardStyle" TargetType="Border" BasedOn="{StaticResource CardBorderStyle}">
            <Setter Property="Margin" Value="0,0,12,12"/>
            <Setter Property="Width" Value="170"/>
            <Setter Property="Padding" Value="12"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource CardBorderStyle}"
                Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="{Binding WindowTitle}"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="#0B1220"/>
                <TextBlock Text="{Binding Subtitle}"
                           Margin="0,6,0,0"
                           Foreground="#6B7280"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <Border Style="{StaticResource CardBorderStyle}"
                        Visibility="{Binding HasSummary, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock Text="摘要说明"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#0B1220"/>
                        <TextBlock Text="{Binding Summary}"
                                   Margin="0,10,0,0"
                                   Foreground="#475569"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorderStyle}"
                        Margin="0,14,0,0"
                        Visibility="{Binding HasMetrics, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock Text="关键数据"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#0B1220"/>
                        <ItemsControl ItemsSource="{Binding Metrics}"
                                      Margin="0,12,0,0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource MetricCardStyle}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Border Width="36"
                                                    Height="4"
                                                    CornerRadius="2"
                                                    HorizontalAlignment="Left"
                                                    Background="{Binding AccentBrush}"/>
                                            <TextBlock Grid.Row="1"
                                                       Text="{Binding Name}"
                                                       Margin="0,12,0,6"
                                                       Foreground="#64748B"
                                                       FontSize="12"/>
                                            <TextBlock Grid.Row="1"
                                                       Margin="0,30,0,0"
                                                       Text="{Binding Value}"
                                                       Foreground="#111827"
                                                       FontSize="22"
                                                       FontWeight="SemiBold"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorderStyle}"
                        Margin="0,14,0,12"
                        Visibility="{Binding HasDetailTable, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock Text="明细信息"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#0B1220"/>
                        <DataGrid Margin="0,12,0,0"
                                  ItemsSource="{Binding DetailTableView}"
                                  AutoGenerateColumns="True"
                                  HeadersVisibility="Column"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  CanUserResizeRows="False"
                                  BorderBrush="#E5E7EB"
                                  BorderThickness="1"
                                  Background="White"
                                  RowBackground="White"
                                  AlternatingRowBackground="#F8FAFC"
                                  GridLinesVisibility="Horizontal"
                                  SelectionMode="Single"
                                  SelectionUnit="FullRow"
                                  VerticalScrollBarVisibility="Auto"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>

<Window x:Class="EW_Assistant.Views.Reports.ReportDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:md="clr-namespace:MdXaml;assembly=MdXaml"
        xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        xmlns:skia="clr-namespace:SkiaSharp.Views.WPF;assembly=SkiaSharp.Views.WPF"
        Title="报表详情"
        Width="1180"
        Height="860"
        MinWidth="980"
        MinHeight="720"
        WindowStartupLocation="CenterOwner"
        Background="#F3F4F6"
        FontFamily="{StaticResource AppFontFamily}"
        FontSize="14">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="12"/>
        </Style>

        <Style x:Key="KpiCardStyle" TargetType="Border" BasedOn="{StaticResource CardBorderStyle}">
            <Setter Property="Padding" Value="14"/>
            <Setter Property="Margin" Value="0,0,12,12"/>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#0B1220"/>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Background" Value="#F3F6FF"/>
            <Setter Property="Foreground" Value="#1F2937"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                CornerRadius="18"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E1E9FF"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#90A4F4"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#CBD7FF"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#6B82F3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource CardBorderStyle}"
                Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{Binding ReportTitle}"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="#0B1220"/>
                    <TextBlock Text="{Binding ReportMetaText}"
                               Margin="0,6,0,0"
                               Foreground="#6B7280"
                               TextWrapping="Wrap"/>
                </StackPanel>
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Content="导出报表"
                            Style="{StaticResource ActionButtonStyle}"
                            Click="ExportButton_Click"/>
                    <Button Content="打开所在文件夹"
                            Style="{StaticResource ActionButtonStyle}"
                            Click="OpenFolderButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer x:Name="ContentScrollViewer"
                      Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <TextBlock Text="关键指标"
                           Style="{StaticResource SectionTitleStyle}"/>

                <Grid Margin="0,12,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <ItemsControl Grid.Column="0"
                                  ItemsSource="{Binding PreviewKpis}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <primitives:UniformGrid Columns="4"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource KpiCardStyle}"
                                        MinHeight="116">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <Border Width="38"
                                                Height="4"
                                                CornerRadius="2"
                                                Background="{Binding AccentBrush}"
                                                HorizontalAlignment="Left"/>
                                        <TextBlock Grid.Row="1"
                                                   Text="{Binding Title}"
                                                   Foreground="#64748B"
                                                   FontSize="12"
                                                   Margin="0,12,0,6"/>
                                        <TextBlock Grid.Row="2"
                                                   Text="{Binding Value}"
                                                   Foreground="#111827"
                                                   FontSize="24"
                                                   FontWeight="Bold"/>
                                        <TextBlock Grid.Row="2"
                                                   Margin="0,34,0,0"
                                                   Text="{Binding Hint}"
                                                   Foreground="#6B7280"
                                                   FontSize="12"
                                                   TextWrapping="Wrap"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Border Grid.Column="1"
                            Width="228"
                            Margin="12,0,0,12"
                            Style="{StaticResource CardBorderStyle}"
                            Visibility="{Binding HasCompactTertiaryChart, Converter={StaticResource BoolToVisibilityConverter}}"
                            PreviewMouseWheel="NestedScrollRegion_PreviewMouseWheel">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="{Binding TertiaryChart.Title}"
                                       Style="{StaticResource SectionTitleStyle}"
                                       FontSize="15"/>
                            <TextBlock Grid.Row="1"
                                       Text="{Binding TertiaryChart.Subtitle}"
                                       Foreground="#6B7280"
                                       Margin="0,4,0,0"
                                       FontSize="12"
                                       TextWrapping="Wrap"/>
                            <ItemsControl Grid.Row="2"
                                          ItemsSource="{Binding TertiaryChart.Series}"
                                          Margin="0,8,0,0">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,10,6">
                                            <Ellipse Width="9" Height="9" Fill="{Binding LegendBrush}" Margin="0,0,5,0"/>
                                            <TextBlock Text="{Binding Name}" Foreground="#475569" FontSize="12"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <skia:SKElement x:Name="CompactTertiaryChartCanvas"
                                            Grid.Row="3"
                                            Height="82"
                                            Margin="0,4,0,0"
                                            MouseMove="ChartCanvas_MouseMove"
                                            MouseLeave="ChartCanvas_MouseLeave"
                                            PreviewMouseLeftButtonUp="ChartCanvas_PreviewMouseLeftButtonUp"
                                            PaintSurface="TertiaryChart_PaintSurface"/>
                        </Grid>
                    </Border>
                </Grid>

                <Grid Margin="0,8,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Row="0"
                            Grid.Column="0"
                            Style="{StaticResource CardBorderStyle}"
                            Visibility="{Binding HasPrimaryChart, Converter={StaticResource BoolToVisibilityConverter}}"
                            PreviewMouseWheel="NestedScrollRegion_PreviewMouseWheel">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="{Binding PrimaryChart.Title}"
                                       Style="{StaticResource SectionTitleStyle}"/>
                            <TextBlock Grid.Row="1"
                                       Text="{Binding PrimaryChart.Subtitle}"
                                       Foreground="#6B7280"
                                       Margin="0,4,0,0"
                                       TextWrapping="Wrap"/>
                            <ItemsControl Grid.Row="2"
                                          ItemsSource="{Binding PrimaryChart.Series}"
                                          Margin="0,10,0,6">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,12,6">
                                            <Ellipse Width="10" Height="10" Fill="{Binding LegendBrush}" Margin="0,0,6,0"/>
                                            <TextBlock Text="{Binding Name}" Foreground="#475569" FontSize="12"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <skia:SKElement x:Name="PrimaryChartCanvas"
                                            Grid.Row="3"
                                            Height="240"
                                            MouseMove="ChartCanvas_MouseMove"
                                            MouseLeave="ChartCanvas_MouseLeave"
                                            PreviewMouseLeftButtonUp="ChartCanvas_PreviewMouseLeftButtonUp"
                                            PaintSurface="PrimaryChart_PaintSurface"/>
                        </Grid>
                    </Border>

                    <Border Grid.Row="0"
                            Grid.Column="2"
                            Style="{StaticResource CardBorderStyle}"
                            Visibility="{Binding HasSecondaryChart, Converter={StaticResource BoolToVisibilityConverter}}"
                            PreviewMouseWheel="NestedScrollRegion_PreviewMouseWheel">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="{Binding SecondaryChart.Title}"
                                       Style="{StaticResource SectionTitleStyle}"/>
                            <TextBlock Grid.Row="1"
                                       Text="{Binding SecondaryChart.Subtitle}"
                                       Foreground="#6B7280"
                                       Margin="0,4,0,0"
                                       TextWrapping="Wrap"/>
                            <ItemsControl Grid.Row="2"
                                          ItemsSource="{Binding SecondaryChart.Series}"
                                          Margin="0,10,0,6">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,12,6">
                                            <Ellipse Width="10" Height="10" Fill="{Binding LegendBrush}" Margin="0,0,6,0"/>
                                            <TextBlock Text="{Binding Name}" Foreground="#475569" FontSize="12"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <skia:SKElement x:Name="SecondaryChartCanvas"
                                            Grid.Row="3"
                                            Height="240"
                                            MouseMove="ChartCanvas_MouseMove"
                                            MouseLeave="ChartCanvas_MouseLeave"
                                            PreviewMouseLeftButtonUp="ChartCanvas_PreviewMouseLeftButtonUp"
                                            PaintSurface="SecondaryChart_PaintSurface"/>
                        </Grid>
                    </Border>

                    <Border Grid.Row="2"
                            Grid.ColumnSpan="3"
                            Style="{StaticResource CardBorderStyle}"
                            Visibility="{Binding HasStandaloneTertiaryChart, Converter={StaticResource BoolToVisibilityConverter}}"
                            PreviewMouseWheel="NestedScrollRegion_PreviewMouseWheel">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="{Binding TertiaryChart.Title}"
                                       Style="{StaticResource SectionTitleStyle}"/>
                            <TextBlock Grid.Row="1"
                                       Text="{Binding TertiaryChart.Subtitle}"
                                       Foreground="#6B7280"
                                       Margin="0,4,0,0"
                                       TextWrapping="Wrap"/>
                            <ItemsControl Grid.Row="2"
                                          ItemsSource="{Binding TertiaryChart.Series}"
                                          Margin="0,10,0,6">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,12,6">
                                            <Ellipse Width="10" Height="10" Fill="{Binding LegendBrush}" Margin="0,0,6,0"/>
                                            <TextBlock Text="{Binding Name}" Foreground="#475569" FontSize="12"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <skia:SKElement x:Name="StandaloneTertiaryChartCanvas"
                                            Grid.Row="3"
                                            Height="260"
                                            MouseMove="ChartCanvas_MouseMove"
                                            MouseLeave="ChartCanvas_MouseLeave"
                                            PreviewMouseLeftButtonUp="ChartCanvas_PreviewMouseLeftButtonUp"
                                            PaintSurface="TertiaryChart_PaintSurface"/>
                        </Grid>
                    </Border>
                </Grid>

                <Border Style="{StaticResource CardBorderStyle}"
                        Margin="0,14,0,0"
                        PreviewMouseWheel="NestedScrollRegion_PreviewMouseWheel">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="AI 分析正文"
                                   Style="{StaticResource SectionTitleStyle}"/>
                        <md:MarkdownScrollViewer Grid.Row="1"
                                                 Markdown="{Binding PreviewMarkdown}"
                                                 Background="White"
                                                 BorderThickness="0"
                                                 Padding="0,12,0,0"
                                                 TextElement.FontFamily="{StaticResource AppFontFamily}"
                                                 VerticalScrollBarVisibility="Disabled"/>
                    </Grid>
                </Border>

                <Border Style="{StaticResource CardBorderStyle}"
                        Margin="0,14,0,0"
                        Visibility="{Binding HasDetailTable, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="{Binding DetailTitle}"
                                   Style="{StaticResource SectionTitleStyle}"/>
                        <DataGrid Grid.Row="1"
                                  x:Name="DetailTableGrid"
                                  Margin="0,12,0,0"
                                  MaxHeight="360"
                                  ItemsSource="{Binding DetailTableView}"
                                  AutoGenerateColumns="True"
                                  HeadersVisibility="Column"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  CanUserResizeRows="False"
                                  BorderBrush="#E5E7EB"
                                  BorderThickness="1"
                                  Background="White"
                                  RowBackground="White"
                                  AlternatingRowBackground="#F8FAFC"
                                  GridLinesVisibility="Horizontal"
                                  SelectionMode="Single"
                                  SelectionUnit="FullRow"
                                  PreviewMouseWheel="DetailTableGrid_PreviewMouseWheel"
                                  VerticalScrollBarVisibility="Auto"/>
                    </Grid>
                </Border>

                <Border Style="{StaticResource CardBorderStyle}"
                        Margin="0,14,0,12"
                        Visibility="{Binding HasPreviewNotes, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="注意事项"
                                   Style="{StaticResource SectionTitleStyle}"/>
                        <ItemsControl Grid.Row="1"
                                      ItemsSource="{Binding PreviewNotes}"
                                      Margin="0,12,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding StringFormat=- {0}}"
                                               Foreground="#6B7280"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,8"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Popup x:Name="ChartTooltipPopup"
               Placement="Relative"
               AllowsTransparency="True"
               PopupAnimation="Fade"
               StaysOpen="True"
               IsHitTestVisible="False">
            <Border Background="#0F172A"
                    BorderBrush="#1E293B"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="12,10"
                    MaxWidth="260"
                    Opacity="0.96">
                <TextBlock x:Name="ChartTooltipTextBlock"
                           Foreground="White"
                           FontSize="12"
                           TextWrapping="Wrap"/>
            </Border>
        </Popup>
    </Grid>
</Window>

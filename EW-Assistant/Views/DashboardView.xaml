<UserControl x:Class="EW_Assistant.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:skia="clr-namespace:SkiaSharp.Views.WPF;assembly=SkiaSharp.Views.WPF"
             mc:Ignorable="d"
             d:DesignHeight="720"
             d:DesignWidth="1100">
    <UserControl.Resources>
        <DropShadowEffect x:Key="CardShadow"
                          Color="#220F172A"
                          BlurRadius="18"
                          ShadowDepth="2"
                          Opacity="0.18"/>

        <Style x:Key="DashboardCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="BorderBrush" Value="#E4E7EC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect" Value="{StaticResource CardShadow}"/>
        </Style>

        <Style x:Key="CardTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#101828"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>

        <Style x:Key="CardSubtitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#667085"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>

        <Style x:Key="MetricLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#667085"/>
        </Style>

        <Style x:Key="MetricValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#101828"/>
            <Setter Property="Margin" Value="0,3,0,0"/>
        </Style>

        <Style x:Key="SlimProgressBar" TargetType="ProgressBar">
            <Setter Property="Height" Value="12"/>
            <Setter Property="Background" Value="#EEF2F7"/>
            <Setter Property="Foreground" Value="#2563EB"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid SnapsToDevicePixels="True">
                            <Border x:Name="PART_Track"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="6"/>
                            <Border x:Name="PART_Indicator"
                                    Background="{TemplateBinding Foreground}"
                                    CornerRadius="6"
                                    HorizontalAlignment="Left"
                                    Width="0"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="#F3F5F8">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="22">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="18"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="18"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="18"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        CornerRadius="8"
                        Padding="22"
                        Background="#FFFFFF"
                        BorderBrush="#E4E7EC"
                        BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="18"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0"
                                    VerticalAlignment="Center">
                            <TextBlock Text="生产运行总览"
                                       FontSize="26"
                                       FontWeight="SemiBold"
                                       Foreground="#101828"/>
                            <TextBlock Text="产能、良率与报警趋势"
                                       FontSize="13"
                                       Foreground="#667085"
                                       Margin="0,7,0,0"/>
                        </StackPanel>

                        <Border Grid.Column="2"
                                Width="138"
                                MinHeight="66"
                                CornerRadius="8"
                                Padding="14,10"
                                Background="#F8FAFC"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock Style="{StaticResource MetricLabel}" Text="统计口径"/>
                                <TextBlock Style="{StaticResource MetricValue}" Text="PASS+FAIL"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="4"
                                Width="138"
                                MinHeight="66"
                                CornerRadius="8"
                                Padding="14,10"
                                Background="#F8FAFC"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock Style="{StaticResource MetricLabel}" Text="刷新频率"/>
                                <TextBlock Style="{StaticResource MetricValue}" Text="10 秒"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="6"
                                Width="138"
                                MinHeight="66"
                                CornerRadius="8"
                                Padding="14,10"
                                Background="#F8FAFC"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock Style="{StaticResource MetricLabel}" Text="数据窗口"/>
                                <TextBlock Style="{StaticResource MetricValue}" Text="7 天"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="18"/>
                        <ColumnDefinition Width="314"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Style="{StaticResource DashboardCard}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="14"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0">
                                <TextBlock Text="最近一周产能趋势" Style="{StaticResource CardTitle}"/>
                                <TextBlock x:Name="Subtitle" Text="统计：PASS+FAIL" Style="{StaticResource CardSubtitle}"/>
                            </StackPanel>
                            <skia:SKElement x:Name="SkChart"
                                            Grid.Row="2"
                                            HorizontalAlignment="Center"
                                            Width="{Binding WeekChartWidth, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            Height="{Binding WeekChartHeight, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            PaintSurface="SkChart_PaintSurface"/>
                        </Grid>
                    </Border>

                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="18"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Style="{StaticResource DashboardCard}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="10"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="今日良率" Style="{StaticResource CardTitle}"/>
                                <skia:SKElement x:Name="SkYield"
                                                Grid.Row="2"
                                                HorizontalAlignment="Center"
                                                Width="{Binding YieldCardWidth, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                Height="{Binding YieldCardHeight, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                PaintSurface="SkYield_PaintSurface"/>
                            </Grid>
                        </Border>

                        <Border Grid.Row="2"
                                Style="{StaticResource DashboardCard}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="10"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="今日报警类型 TOP5" Style="{StaticResource CardTitle}"/>
                                <skia:SKElement x:Name="SkTop5"
                                                Grid.Row="2"
                                                HorizontalAlignment="Center"
                                                Width="276"
                                                Height="235"
                                                PaintSurface="SkTop5_PaintSurface"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>

                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="18"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Style="{StaticResource DashboardCard}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="14"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0">
                                <TextBlock Text="今日 24 小时产能分布" Style="{StaticResource CardTitle}"/>
                                <TextBlock Text="统计：PASS+FAIL" Style="{StaticResource CardSubtitle}"/>
                            </StackPanel>
                            <skia:SKElement x:Name="SkHour"
                                            Grid.Row="2"
                                            HorizontalAlignment="Center"
                                            Width="{Binding HourChartWidth, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            Height="{Binding HourChartHeight, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            PaintSurface="SkHour_PaintSurface"/>
                        </Grid>
                    </Border>

                    <Border Grid.Column="2"
                            Style="{StaticResource DashboardCard}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="14"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0">
                                <TextBlock Text="今日 24 小时报警次数" Style="{StaticResource CardTitle}"/>
                                <TextBlock Text="统计：按小时计数" Style="{StaticResource CardSubtitle}"/>
                            </StackPanel>
                            <skia:SKElement x:Name="SkAlarmHour"
                                            Grid.Row="2"
                                            HorizontalAlignment="Center"
                                            Width="{Binding HourChartWidth, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            Height="{Binding HourChartHeight, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            PaintSurface="SkAlarmHour_PaintSurface"/>
                        </Grid>
                    </Border>
                </Grid>

                <Grid Grid.Row="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="18"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Style="{StaticResource DashboardCard}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="14"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0">
                                <TextBlock Text="最近一周报警次数" Style="{StaticResource CardTitle}"/>
                                <TextBlock Text="统计：按天计数" Style="{StaticResource CardSubtitle}"/>
                            </StackPanel>
                            <skia:SKElement x:Name="SkAlarm"
                                            Grid.Row="2"
                                            HorizontalAlignment="Center"
                                            Width="{Binding WeekChartWidth, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            Height="{Binding WeekChartHeight, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            PaintSurface="SkAlarm_PaintSurface"/>
                        </Grid>
                    </Border>

                    <Border Grid.Column="2"
                            Style="{StaticResource DashboardCard}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="14"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0"
                                       Text="今日报警时长占比"
                                       Style="{StaticResource CardTitle}"/>
                            <skia:SKElement x:Name="SkAlarmPie"
                                            Grid.Row="2"
                                            HorizontalAlignment="Center"
                                            Width="440"
                                            Height="235"
                                            PaintSurface="SkAlarmPie_PaintSurface"/>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>

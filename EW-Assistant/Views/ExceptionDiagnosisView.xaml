<UserControl x:Class="EW_Assistant.Views.ExceptionDiagnosisView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:md="clr-namespace:MdXaml;assembly=MdXaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DesignHeight="760"
             d:DesignWidth="1200"
             mc:Ignorable="d">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanVisibilityConverter"/>

        <Style x:Key="SectionCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#FCFDFE"/>
            <Setter Property="CornerRadius" Value="22"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="BorderBrush" Value="#E7EDF5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="20"
                                      ShadowDepth="6"
                                      Opacity="0.06"
                                      Color="#0F172A"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SummaryCaptionTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#334155"/>
        </Style>

        <Style x:Key="SummaryEmptyStateTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="LineHeight" Value="22"/>
        </Style>

        <Style x:Key="RecordSwitchButtonBaseStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Margin" Value="0,0,18,0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Cursor="Hand"
                              Background="Transparent">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="4"/>
                            </Grid.RowDefinitions>
                            <Border x:Name="HoverBackground"
                                    Grid.Row="0"
                                    Margin="0,0,0,4"
                                    CornerRadius="10"
                                    Background="Transparent"/>
                            <ContentPresenter Grid.Row="0"
                                              Margin="12,2,12,8"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              ContentSource="Content"
                                              RecognizesAccessKey="True"/>
                            <Border x:Name="ActiveBar"
                                    Grid.Row="1"
                                    Height="3"
                                    Margin="10,0,10,0"
                                    VerticalAlignment="Bottom"
                                    CornerRadius="999"
                                    Background="#2563EB"
                                    Opacity="0"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HoverBackground" Property="Background" Value="#F8FAFC"/>
                                <Setter Property="Foreground" Value="#334155"/>
                            </Trigger>
                            <Trigger Property="Tag" Value="active">
                                <Setter TargetName="HoverBackground" Property="Background" Value="#F8FAFC"/>
                                <Setter TargetName="ActiveBar" Property="Opacity" Value="1"/>
                                <Setter Property="Foreground" Value="#0F172A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RecentRecordSwitchButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource RecordSwitchButtonBaseStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsRecentRecordsTabActive}" Value="True">
                    <Setter Property="Tag" Value="active"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ArchivedRecordSwitchButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource RecordSwitchButtonBaseStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsArchivedRecordsTabActive}" Value="True">
                    <Setter Property="Tag" Value="active"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TodayQuickButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#D8E1EC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#334155"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="RootBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              ContentSource="Content"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="#F8FAFC"/>
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="#CBD5E1"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="#EEF4FF"/>
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="#93C5FD"/>
                            </Trigger>
                            <Trigger Property="Tag" Value="active">
                                <Setter TargetName="RootBorder" Property="Background" Value="#EFF6FF"/>
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="#BFDBFE"/>
                                <Setter Property="Foreground" Value="#1D4ED8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsTodayRecordDateSelected}" Value="True">
                    <Setter Property="Tag" Value="active"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RecordListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
            <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True"/>
            <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling"/>
        </Style>

        <Style x:Key="RecordListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <ContentPresenter/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="NodeRecordItemTemplate">
            <Border Margin="0,0,0,6"
                    Padding="9,7"
                    CornerRadius="10"
                    Background="#F5F9FF"
                    BorderBrush="#D8E8FF"
                    BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="22"
                            Height="22"
                            CornerRadius="11"
                            Background="#2563EB"
                            VerticalAlignment="Top">
                        <TextBlock Text="{Binding IndexText}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="White"/>
                    </Border>
                    <TextBlock Grid.Column="1"
                               Margin="9,1,0,0"
                               Text="{Binding Title}"
                               Foreground="#0F172A"
                               FontSize="12"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               ToolTip="{Binding Title}"/>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="McpRecordItemTemplate">
            <Border Margin="0,0,0,10"
                    Padding="10,9"
                    CornerRadius="14"
                    Background="#F8FAFC"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="24"
                            Height="24"
                            CornerRadius="12"
                            Background="#0F766E"
                            VerticalAlignment="Top">
                        <TextBlock Text="{Binding IndexText}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="White"/>
                    </Border>
                    <TextBlock Grid.Column="1"
                               Margin="10,1,0,0"
                               Text="{Binding Title}"
                               Foreground="#0F172A"
                               FontSize="13"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               ToolTip="{Binding Title}"/>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="TraceItemTemplate">
            <Button x:Name="TraceButton"
                    Click="TraceRecordButton_Click"
                    Tag="{Binding RecordKey}"
                    Margin="0,0,0,10"
                    Padding="0"
                    Background="Transparent"
                    BorderThickness="0"
                    HorizontalContentAlignment="Stretch"
                    FocusVisualStyle="{x:Null}">
                <Border x:Name="TraceBorder"
                        Padding="0"
                        CornerRadius="16"
                        Background="#FEFFFF"
                        BorderBrush="#E6ECF3"
                        BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="4"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border x:Name="TraceAccent"
                                Background="#CBD5E1"
                                CornerRadius="16,0,0,16"/>

                        <StackPanel Grid.Column="1"
                                    Margin="14,12,14,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="{Binding TitleText}"
                                           Margin="0,0,12,0"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="#0F172A"
                                           TextWrapping="NoWrap"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding StartedAtText}"
                                           Foreground="#94A3B8"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                            </Grid>

                            <Grid Margin="0,6,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="{Binding SummaryText}"
                                           Margin="0,0,12,0"
                                           Foreground="#475569"
                                           FontSize="12"
                                           TextWrapping="NoWrap"
                                           TextTrimming="CharacterEllipsis"/>
                                <Border Grid.Column="1"
                                        Padding="8,2"
                                        CornerRadius="999"
                                        Background="#F8FAFC"
                                        BorderBrush="#E2E8F0"
                                        BorderThickness="1">
                                    <TextBlock Text="{Binding StatusText}"
                                               Foreground="#64748B"
                                               FontSize="11"
                                               FontWeight="SemiBold"/>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Border>
            </Button>
            <DataTemplate.Triggers>
                <Trigger SourceName="TraceButton" Property="IsMouseOver" Value="True">
                    <Setter TargetName="TraceBorder" Property="BorderBrush" Value="#CBD5E1"/>
                    <Setter TargetName="TraceBorder" Property="Background" Value="#FFFFFF"/>
                </Trigger>
                <DataTrigger Binding="{Binding StatusLevel}" Value="running">
                    <Setter TargetName="TraceAccent" Property="Background" Value="#60A5FA"/>
                    <Setter TargetName="TraceBorder" Property="BorderBrush" Value="#D9EAFE"/>
                    <Setter TargetName="TraceBorder" Property="Background" Value="#F8FBFF"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding StatusLevel}" Value="ok">
                    <Setter TargetName="TraceAccent" Property="Background" Value="#34D399"/>
                    <Setter TargetName="TraceBorder" Property="BorderBrush" Value="#DCFCE7"/>
                    <Setter TargetName="TraceBorder" Property="Background" Value="#FAFFFC"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding StatusLevel}" Value="warn">
                    <Setter TargetName="TraceAccent" Property="Background" Value="#F59E0B"/>
                    <Setter TargetName="TraceBorder" Property="BorderBrush" Value="#FDE7B0"/>
                    <Setter TargetName="TraceBorder" Property="Background" Value="#FFFCF5"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding StatusLevel}" Value="error">
                    <Setter TargetName="TraceAccent" Property="Background" Value="#F87171"/>
                    <Setter TargetName="TraceBorder" Property="BorderBrush" Value="#FAD4D4"/>
                    <Setter TargetName="TraceBorder" Property="Background" Value="#FFF8F8"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

    </UserControl.Resources>

    <Grid Margin="12">
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0"
                                 EndPoint="1,1">
                <GradientStop Color="#F4F7FB" Offset="0"/>
                <GradientStop Color="#F7FAFE" Offset="0.55"/>
                <GradientStop Color="#F2F6FB" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Grid.Column="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource SectionCardStyle}"
                    Background="#FDFEFF"
                    BorderBrush="#DCE6F4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal">
                        <Border Width="8"
                                Height="8"
                                Margin="0,4,8,0"
                                CornerRadius="4"
                                Background="#2563EB"
                                VerticalAlignment="Top"/>
                        <TextBlock Text="节点记录"
                                   Style="{StaticResource SummaryCaptionTextStyle}"/>
                    </StackPanel>

                    <Grid Grid.Row="1"
                          Margin="0,14,0,0">
                        <ScrollViewer x:Name="CurrentNodeRecordsScrollViewer"
                                      MaxHeight="168"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      Visibility="{Binding HasCurrentNodeRecords, Converter={StaticResource BooleanVisibilityConverter}}">
                            <ItemsControl ItemsSource="{Binding CurrentNodeRecordItems}"
                                          ItemTemplate="{StaticResource NodeRecordItemTemplate}"/>
                        </ScrollViewer>

                        <Border Padding="14"
                                CornerRadius="16"
                                Background="#F8FAFC"
                                BorderBrush="#E8EEF5"
                                BorderThickness="1"
                                Visibility="{Binding HasNoCurrentNodeRecords, Converter={StaticResource BooleanVisibilityConverter}}">
                            <TextBlock Text="{Binding CurrentNodeDetailText}"
                                       Style="{StaticResource SummaryEmptyStateTextStyle}"/>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Style="{StaticResource SectionCardStyle}"
                    Background="#FCFEFD"
                    BorderBrush="#DDECE8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal">
                        <Border Width="8"
                                Height="8"
                                Margin="0,4,8,0"
                                CornerRadius="4"
                                Background="#0F766E"
                                VerticalAlignment="Top"/>
                        <TextBlock Text="MCP记录"
                                   Style="{StaticResource SummaryCaptionTextStyle}"/>
                    </StackPanel>

                    <Grid Grid.Row="1"
                          Margin="0,14,0,0">
                        <ScrollViewer MaxHeight="168"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      Visibility="{Binding HasCurrentMcpRecords, Converter={StaticResource BooleanVisibilityConverter}}">
                            <ItemsControl ItemsSource="{Binding CurrentMcpRecordItems}"
                                          ItemTemplate="{StaticResource McpRecordItemTemplate}"/>
                        </ScrollViewer>

                        <Border Padding="14"
                                CornerRadius="16"
                                Background="#F8FAFC"
                                BorderBrush="#E8EEF5"
                                BorderThickness="1"
                                Visibility="{Binding HasNoCurrentMcpRecords, Converter={StaticResource BooleanVisibilityConverter}}">
                            <TextBlock Text="{Binding CurrentMcpDetailText}"
                                       Style="{StaticResource SummaryEmptyStateTextStyle}"/>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Grid.Column="0"
                Style="{StaticResource SectionCardStyle}">
            <Grid>
                <Grid x:Name="FinalReplyTextHost"
                      ClipToBounds="True">
                    <md:MarkdownScrollViewer x:Name="FinalReplyMarkdownViewer"
                                             Markdown="{Binding CurrentFinalReplyText}"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Padding="2,2,18,6"
                                             FontFamily="{StaticResource AppFontFamily}"
                                             FontSize="18"
                                             TextElement.FontFamily="{StaticResource AppFontFamily}"
                                             TextElement.FontSize="18"
                                             VerticalScrollBarVisibility="Auto">
                        <md:MarkdownScrollViewer.Style>
                            <Style TargetType="{x:Type md:MarkdownScrollViewer}">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsFinalReplyRevealActive}" Value="True">
                                        <Setter Property="Visibility" Value="Hidden"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </md:MarkdownScrollViewer.Style>
                    </md:MarkdownScrollViewer>

                    <ScrollViewer x:Name="FinalReplyRevealScrollViewer"
                                  Padding="2,2,18,6"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Visibility="{Binding IsFinalReplyRevealActive, Converter={StaticResource BooleanVisibilityConverter}}">
                        <TextBlock Text="{Binding AnimatedFinalReplyText}"
                                   FontFamily="{StaticResource AppFontFamily}"
                                   FontSize="18"
                                   Foreground="#111827"
                                   LineHeight="28"
                                   TextWrapping="Wrap"
                                   xml:space="preserve"/>
                    </ScrollViewer>

                    <Border x:Name="FinalReplyGlowOverlay"
                            Width="280"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Stretch"
                            IsHitTestVisible="False"
                            Opacity="0"
                            Visibility="{Binding IsFinalReplyRevealActive, Converter={StaticResource BooleanVisibilityConverter}}">
                        <Border.RenderTransform>
                            <TranslateTransform x:Name="FinalReplyGlowTransform"
                                                X="-320"/>
                        </Border.RenderTransform>
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0"
                                                 EndPoint="1,0">
                                <GradientStop Color="#00FFFFFF"
                                              Offset="0"/>
                                <GradientStop Color="#55BFDBFE"
                                              Offset="0.35"/>
                                <GradientStop Color="#99FFFFFF"
                                              Offset="0.5"/>
                                <GradientStop Color="#55A7F3D0"
                                              Offset="0.65"/>
                                <GradientStop Color="#00FFFFFF"
                                              Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="0"
                Grid.RowSpan="3"
                Grid.Column="2"
                Style="{StaticResource SectionCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Height="1"
                        VerticalAlignment="Bottom"
                        Background="#E5E7EB"/>

                <TextBlock Grid.Row="0"
                           Margin="12,0,0,14"
                           Text="最近记录"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="#0F172A"/>

                <Grid Grid.Row="1"
                      Margin="0,18,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Button Content="待填写"
                                Style="{StaticResource RecentRecordSwitchButtonStyle}"
                                Click="BtnShowRecentRecords_Click"/>
                        <Button Content="已归类"
                                Style="{StaticResource ArchivedRecordSwitchButtonStyle}"
                                Click="BtnShowArchivedRecords_Click"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <DatePicker Width="138"
                                    Height="30"
                                    SelectedDate="{Binding SelectedRecordDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Margin="8,0,0,0"
                                Width="52"
                                Height="30"
                                Content="今天"
                                Style="{StaticResource TodayQuickButtonStyle}"
                                Click="BtnJumpToToday_Click"/>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="2*"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <ListBox Style="{StaticResource RecordListBoxStyle}"
                                 ItemContainerStyle="{StaticResource RecordListBoxItemStyle}"
                                 ItemsSource="{Binding TraceItems}"
                                 ItemTemplate="{StaticResource TraceItemTemplate}"
                                 Visibility="{Binding IsRecentRecordsTabActive, Converter={StaticResource BooleanVisibilityConverter}}"/>
                        <ListBox Style="{StaticResource RecordListBoxStyle}"
                                 ItemContainerStyle="{StaticResource RecordListBoxItemStyle}"
                                 ItemsSource="{Binding ArchivedTraceItems}"
                                 ItemTemplate="{StaticResource TraceItemTemplate}"
                                 Visibility="{Binding IsArchivedRecordsTabActive, Converter={StaticResource BooleanVisibilityConverter}}"/>
                    </Grid>

                    <Border Grid.Row="2"
                            Padding="12"
                            CornerRadius="16"
                            Background="#0F172A"
                            BorderBrush="#1E293B"
                            BorderThickness="1">
                        <Grid>
                            <Image Source="{Binding CurrentVisionImagePath}"
                                   Stretch="Uniform"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Cursor="Hand"
                                   MouseLeftButtonDown="VisionImage_MouseLeftButtonDown"
                                   Visibility="{Binding HasCurrentVisionImage, Converter={StaticResource BooleanVisibilityConverter}}"/>
                            <Border CornerRadius="12"
                                    Background="#111827"
                                    BorderBrush="#334155"
                                    BorderThickness="1"
                                    Visibility="{Binding HasNoCurrentVisionImage, Converter={StaticResource BooleanVisibilityConverter}}">
                                <TextBlock Text="暂无视觉图片"
                                           Margin="12"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="#94A3B8"
                                           FontSize="12"
                                           FontWeight="SemiBold"/>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>

<UserControl x:Class="EW_Assistant.Views.UiRuntimeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DesignHeight="720"
             d:DesignWidth="1100"
             mc:Ignorable="d">
    <Grid Background="#F5F7FB">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="400"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Padding="14"
                    Background="White"
                    CornerRadius="18"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="任务"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="#111827"/>

                    <Grid Grid.Row="1" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="84"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Goal"
                                   VerticalAlignment="Top"
                                   Foreground="#374151"/>
                        <TextBox Grid.Column="1"
                                 MinHeight="88"
                                 Padding="10"
                                 AcceptsReturn="True"
                                 Text="{Binding TaskGoal, UpdateSourceTrigger=PropertyChanged}"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"/>
                    </Grid>

                    <Grid Grid.Row="3" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="84"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="延时"
                                   VerticalAlignment="Center"
                                   Foreground="#374151"/>
                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal">
                            <TextBox Width="72"
                                     Height="30"
                                     Text="{Binding StartDelaySecondsText, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Margin="8,0,0,0"
                                       VerticalAlignment="Center"
                                       Text="秒"
                                       Foreground="#64748B"/>
                        </StackPanel>
                    </Grid>

                    <CheckBox Grid.Row="4"
                              Margin="84,10,0,0"
                              VerticalAlignment="Center"
                              IsChecked="{Binding BrainDryRunEnabled}"
                              Content="Brain Dry Run（只跑主脑，不启动 executor）"
                              Foreground="#374151"/>

                    <TextBlock Grid.Row="6"
                               Text="跟踪"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#111827"/>

                    <Grid Grid.Row="7" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="84"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Route"
                                   VerticalAlignment="Center"
                                   Foreground="#374151"/>
                        <TextBox Grid.Column="1"
                                 Height="30"
                                 IsReadOnly="True"
                                 Text="{Binding CurrentRouteTraceId, Mode=OneWay}"/>
                    </Grid>

                    <Grid Grid.Row="8" Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="84"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="RunId"
                                   VerticalAlignment="Center"
                                   Foreground="#374151"/>
                        <TextBox Grid.Column="1"
                                 Height="30"
                                 IsReadOnly="True"
                                 Text="{Binding CurrentWorkflowRunId, Mode=OneWay}"/>
                    </Grid>

                    <Grid Grid.Row="9" Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="84"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="TaskId"
                                   VerticalAlignment="Center"
                                   Foreground="#374151"/>
                        <TextBox Grid.Column="1"
                                 Height="30"
                                 IsReadOnly="True"
                                 Text="{Binding CurrentWorkflowTaskId, Mode=OneWay}"/>
                    </Grid>

                    <WrapPanel Grid.Row="10"
                               Margin="0,10,0,0">
                        <Button MinWidth="92"
                                Height="30"
                                Margin="0,0,8,8"
                                Content="复制 Route"
                                Click="BtnCopyCurrentRouteTraceId_Click"/>
                        <Button MinWidth="92"
                                Height="30"
                                Margin="0,0,8,8"
                                Content="复制 RunId"
                                Click="BtnCopyCurrentWorkflowRunId_Click"/>
                        <Button MinWidth="92"
                                Height="30"
                                Margin="0,0,8,8"
                                Content="复制 TaskId"
                                Click="BtnCopyCurrentWorkflowTaskId_Click"/>
                    </WrapPanel>

                    <StackPanel Grid.Row="12"
                                Orientation="Horizontal">
                        <Button Width="150"
                                Height="34"
                                Content="启动"
                                IsEnabled="{Binding CanStartTask}"
                                Click="BtnStartTask_Click"/>
                        <Button Width="150"
                                Height="34"
                                Margin="10,0,0,0"
                                Content="停止"
                                IsEnabled="{Binding CanStopTask}"
                                Background="#FEE2E2"
                                BorderBrush="#FCA5A5"
                                Foreground="#B91C1C"
                                Click="BtnStopTask_Click"/>
                    </StackPanel>

                    <StackPanel Grid.Row="13" Margin="0,12,0,0">
                        <TextBlock Text="{Binding TaskStatus}"
                                   Foreground="#0F766E"
                                   TextWrapping="Wrap"/>
                        <TextBlock Margin="0,6,0,0"
                                   Text="{Binding ActivityStatus}"
                                   Foreground="#1D4ED8"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Padding="14"
                    Background="White"
                    CornerRadius="18"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="实时日志"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#111827"/>

                        <WrapPanel Grid.Column="1"
                                   HorizontalAlignment="Right">
                            <Button MinWidth="92"
                                    Height="30"
                                    Margin="0,0,8,0"
                                    Content="复制日志"
                                    Click="BtnCopyLatestResponseJson_Click"/>
                            <Button MinWidth="92"
                                    Height="30"
                                    Content="清空显示"
                                    Click="BtnClearLatestResponseJson_Click"/>
                        </WrapPanel>
                    </Grid>

                    <TextBox Grid.Row="1"
                             FontFamily="Consolas"
                             FontSize="12.5"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             AcceptsTab="True"
                             TextWrapping="NoWrap"
                             HorizontalScrollBarVisibility="Auto"
                             VerticalScrollBarVisibility="Auto"
                             Text="{Binding LatestResponseJson}"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>

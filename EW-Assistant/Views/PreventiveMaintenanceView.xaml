<UserControl x:Class="EW_Assistant.Views.PreventiveMaintenanceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:skia="clr-namespace:SkiaSharp.Views.WPF;assembly=SkiaSharp.Views.WPF"
             mc:Ignorable="d"
             FontFamily="{StaticResource AppFontFamily}"
             FontSize="14"
             d:DesignHeight="720"
             d:DesignWidth="1100">
    <UserControl.Resources>
        <DropShadowEffect x:Key="CardShadow"
                          Color="#220F172A"
                          BlurRadius="18"
                          ShadowDepth="2"
                          Opacity="0.18"/>

        <Style x:Key="MaintenanceCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="BorderBrush" Value="#E4E7EC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect" Value="{StaticResource CardShadow}"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="MinWidth" Value="108"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#2563EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="#F3F4F6">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="16,16,16,8"
                Style="{StaticResource MaintenanceCard}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="AI 预防性维护"
                               FontSize="26"
                               FontWeight="SemiBold"
                               Foreground="#111827"/>
                    <TextBlock Margin="0,6,0,0"
                               Text="{Binding StatusText}"
                               Foreground="#667085"/>
                    <TextBlock Margin="0,4,0,0"
                               Text="{Binding RootPathText}"
                               Foreground="#98A2B3"
                               TextTrimming="CharacterEllipsis"/>

                    <UniformGrid Margin="0,16,0,0"
                                 Columns="3"
                                 MaxWidth="640"
                                 HorizontalAlignment="Left">
                        <StackPanel>
                            <TextBlock Text="CSV 文件" Foreground="#667085"/>
                            <TextBlock Text="{Binding FileCountText}"
                                       Margin="0,4,0,0"
                                       FontSize="24"
                                       FontWeight="SemiBold"
                                       Foreground="#111827"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="数据锚点" Foreground="#667085"/>
                            <TextBlock Text="{Binding LatestDateText}"
                                       Margin="0,4,0,0"
                                       FontSize="24"
                                       FontWeight="SemiBold"
                                       Foreground="#111827"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="分析对象" Foreground="#667085"/>
                            <TextBlock Text="气缸 / 真空吸"
                                       Margin="0,4,0,0"
                                       FontSize="24"
                                       FontWeight="SemiBold"
                                       Foreground="#111827"/>
                        </StackPanel>
                    </UniformGrid>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="重新分析"
                        VerticalAlignment="Center"
                        Style="{StaticResource PrimaryButton}"
                        Click="BtnRefresh_Click"/>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1"
                      Margin="16,8,16,16"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <Border Style="{StaticResource MaintenanceCard}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="280"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="14"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="气缸数据趋势"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="#111827"/>
                        <skia:SKElement x:Name="CylinderChart"
                                        Grid.Row="2"
                                        PaintSurface="CylinderChart_PaintSurface"/>
                        <TextBlock Grid.Row="3"
                                   Margin="0,10,0,0"
                                   Text="{Binding CylinderSummary}"
                                   TextWrapping="Wrap"
                                   Foreground="#667085"/>

                        <DataGrid Grid.Row="5"
                                  ItemsSource="{Binding CylinderStatuses}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  RowHeaderWidth="0"
                                  MaxHeight="320"
                                  BorderBrush="#E4E7EC"
                                  BorderThickness="1">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="气缸" Binding="{Binding ComponentName}" Width="1.8*"/>
                                <DataGridTextColumn Header="来源" Binding="{Binding SourceNames}" Width="100"/>
                                <DataGridTextColumn Header="样本" Binding="{Binding SampleCount}" Width="70"/>
                                <DataGridTextColumn Header="平均" Binding="{Binding AverageValue, StringFormat=0.###}" Width="80"/>
                                <DataGridTextColumn Header="最大" Binding="{Binding MaxValue, StringFormat=0.###}" Width="80"/>
                                <DataGridTextColumn Header="最新" Binding="{Binding LatestValue, StringFormat=0.###}" Width="80"/>
                                <DataGridTextColumn Header="风险" Binding="{Binding RiskLevel}" Width="90"/>
                                <DataGridTextColumn Header="分数" Binding="{Binding RiskScore}" Width="70"/>
                                <DataGridTextColumn Header="建议" Binding="{Binding Suggestion}" Width="2*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <Border Margin="0,16,0,0"
                        Style="{StaticResource MaintenanceCard}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="280"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="14"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="吸嘴数据趋势"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="#111827"/>
                        <skia:SKElement x:Name="VacuumChart"
                                        Grid.Row="2"
                                        PaintSurface="VacuumChart_PaintSurface"/>
                        <TextBlock Grid.Row="3"
                                   Margin="0,10,0,0"
                                   Text="{Binding VacuumSummary}"
                                   TextWrapping="Wrap"
                                   Foreground="#667085"/>

                        <DataGrid Grid.Row="5"
                                  ItemsSource="{Binding VacuumStatuses}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  RowHeaderWidth="0"
                                  MaxHeight="320"
                                  BorderBrush="#E4E7EC"
                                  BorderThickness="1">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="吸嘴" Binding="{Binding ComponentName}" Width="1.8*"/>
                                <DataGridTextColumn Header="来源" Binding="{Binding SourceNames}" Width="100"/>
                                <DataGridTextColumn Header="样本" Binding="{Binding SampleCount}" Width="70"/>
                                <DataGridTextColumn Header="平均" Binding="{Binding AverageValue, StringFormat=0.###}" Width="80"/>
                                <DataGridTextColumn Header="最大" Binding="{Binding MaxValue, StringFormat=0.###}" Width="80"/>
                                <DataGridTextColumn Header="最新" Binding="{Binding LatestValue, StringFormat=0.###}" Width="80"/>
                                <DataGridTextColumn Header="风险" Binding="{Binding RiskLevel}" Width="90"/>
                                <DataGridTextColumn Header="分数" Binding="{Binding RiskScore}" Width="70"/>
                                <DataGridTextColumn Header="建议" Binding="{Binding Suggestion}" Width="2*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <Border Margin="0,16,0,0"
                        Style="{StaticResource MaintenanceCard}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="风险提示与维护建议"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="#111827"/>

                        <DataGrid Grid.Row="2"
                                  ItemsSource="{Binding Risks}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  RowHeaderWidth="0"
                                  MinHeight="120"
                                  BorderBrush="#E4E7EC"
                                  BorderThickness="1">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="零件" Binding="{Binding PartName}" Width="90"/>
                                <DataGridTextColumn Header="风险" Binding="{Binding RiskLevel}" Width="90"/>
                                <DataGridTextColumn Header="分数" Binding="{Binding RiskScore}" Width="70"/>
                                <DataGridTextColumn Header="提示" Binding="{Binding Summary}" Width="2*"/>
                                <DataGridTextColumn Header="建议" Binding="{Binding Suggestion}" Width="2*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>

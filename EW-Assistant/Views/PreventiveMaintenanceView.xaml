<UserControl x:Class="EW_Assistant.Views.PreventiveMaintenanceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:skia="clr-namespace:SkiaSharp.Views.WPF;assembly=SkiaSharp.Views.WPF"
             mc:Ignorable="d"
             FontFamily="{StaticResource AppFontFamily}"
             FontSize="14"
             d:DesignHeight="720"
             d:DesignWidth="1100">
    <UserControl.Resources>
        <DropShadowEffect x:Key="CardShadow"
                          Color="#220F172A"
                          BlurRadius="18"
                          ShadowDepth="2"
                          Opacity="0.18"/>

        <Style x:Key="MaintenanceCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="BorderBrush" Value="#E4E7EC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect" Value="{StaticResource CardShadow}"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="MinWidth" Value="108"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#2563EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="TrendSelectorComboBoxItem" TargetType="ComboBoxItem">
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style x:Key="TrendSelectorComboBox" TargetType="ComboBox">
            <Setter Property="Width" Value="185"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D9DDE5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#1F2937"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource TrendSelectorComboBoxItem}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid SnapsToDevicePixels="True">
                            <Border x:Name="Chrome"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6"/>

                            <TextBlock Margin="16,0,34,0"
                                       VerticalAlignment="Center"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontSize="{TemplateBinding FontSize}"
                                       IsHitTestVisible="False"
                                       Text="{Binding SelectedItem.ComponentName, RelativeSource={RelativeSource TemplatedParent}}"
                                       TextTrimming="CharacterEllipsis"/>
                            <Path Width="12"
                                  Height="7"
                                  Margin="0,0,12,0"
                                  HorizontalAlignment="Right"
                                  VerticalAlignment="Center"
                                  Data="M 1 1 L 6 6 L 11 1"
                                  IsHitTestVisible="False"
                                  Stroke="#4B5563"
                                  StrokeThickness="1.8"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Stretch="None"/>

                            <ToggleButton Background="Transparent"
                                          BorderThickness="0"
                                          ClickMode="Press"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}"/>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   PopupAnimation="Slide">
                                <Grid MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                      MaxHeight="260">
                                    <Border Margin="0,4,0,0"
                                            Background="White"
                                            BorderBrush="#D9DDE5"
                                            BorderThickness="1"
                                            CornerRadius="6">
                                        <ScrollViewer Margin="2"
                                                      CanContentScroll="True">
                                            <ItemsPresenter/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#C3CAD5"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#94A3B8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MaintenanceDataGridColumnHeader" TargetType="DataGridColumnHeader">
            <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
            <Setter Property="TextOptions.TextRenderingMode" Value="Grayscale"/>
            <Setter Property="TextOptions.TextHintingMode" Value="Fixed"/>
        </Style>

        <Style x:Key="MaintenanceRiskColumnHeader" TargetType="DataGridColumnHeader" BasedOn="{StaticResource MaintenanceDataGridColumnHeader}">
            <Setter Property="Background" Value="#FDBA74"/>
            <Setter Property="BorderBrush" Value="#F59E0B"/>
        </Style>

        <Style x:Key="MaintenanceDataGridCell" TargetType="DataGridCell">
            <Setter Property="MinHeight" Value="26"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
            <Setter Property="TextOptions.TextRenderingMode" Value="Grayscale"/>
            <Setter Property="TextOptions.TextHintingMode" Value="Fixed"/>
        </Style>

        <Style x:Key="MaintenanceDataGridText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
            <Setter Property="TextOptions.TextRenderingMode" Value="Grayscale"/>
            <Setter Property="TextOptions.TextHintingMode" Value="Fixed"/>
        </Style>

        <Style x:Key="MaintenanceDataGrid" TargetType="DataGrid">
            <Setter Property="RowHeight" Value="28"/>
            <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="UseLayoutRounding" Value="True"/>
            <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
            <Setter Property="TextOptions.TextRenderingMode" Value="Grayscale"/>
            <Setter Property="TextOptions.TextHintingMode" Value="Fixed"/>
            <Setter Property="ColumnHeaderStyle" Value="{StaticResource MaintenanceDataGridColumnHeader}"/>
            <Setter Property="CellStyle" Value="{StaticResource MaintenanceDataGridCell}"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="EnableColumnVirtualization" Value="True"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="MaxHeight" Value="320"/>
            <Setter Property="BorderBrush" Value="#E4E7EC"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="RiskSummaryBox" TargetType="Border">
            <Setter Property="Background" Value="#FFF7ED"/>
            <Setter Property="BorderBrush" Value="#FDBA74"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>

        <Style x:Key="RiskSummaryTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#111827"/>
        </Style>

        <Style x:Key="RiskSummaryText" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,4,0,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#667085"/>
            <Setter Property="TextWrapping" Value="NoWrap"/>
        </Style>

        <Style x:Key="AiSuggestionPanel" TargetType="Border">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="#BFDBFE"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="MinWidth" Value="220"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
        </Style>

        <Style x:Key="AiSuggestionBadge" TargetType="Border">
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Background" Value="#E0F2FE"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>

        <Style x:Key="AiSuggestionText" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,12,0,0"/>
            <Setter Property="FontFamily" Value="Microsoft YaHei UI, Microsoft YaHei, Source Han Sans SC, Noto Sans CJK SC"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="LineHeight" Value="27"/>
            <Setter Property="Foreground" Value="#1F2937"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="TextOptions.TextFormattingMode" Value="Ideal"/>
            <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
            <Setter Property="TextOptions.TextHintingMode" Value="Fixed"/>
        </Style>

        <Style x:Key="AiSuggestionFailureText" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,8,0,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#DC2626"/>
            <Setter Property="Visibility" Value="Visible"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding AiSuggestionFailureMessage}" Value="">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding AiSuggestionFailureMessage}" Value="{x:Null}">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="AiSuggestionProgressBar" TargetType="ProgressBar">
            <Setter Property="Height" Value="8"/>
            <Setter Property="Width" Value="480"/>
            <Setter Property="Margin" Value="0,8,0,0"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Background" Value="#E8EEF7"/>
            <Setter Property="Visibility" Value="Collapsed"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid ClipToBounds="True" SnapsToDevicePixels="True">
                            <Border x:Name="PART_Track"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="4"/>
                            <Border x:Name="PART_Indicator"
                                    HorizontalAlignment="Left"
                                    CornerRadius="4">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0"
                                                         EndPoint="1,0">
                                        <GradientStop Color="#14B8A6"
                                                      Offset="0"/>
                                        <GradientStop Color="#38BDF8"
                                                      Offset="0.48"/>
                                        <GradientStop Color="#6366F1"
                                                      Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsAiSuggestionRunning}" Value="True">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="AiSuggestionBodyScroll" TargetType="ScrollViewer">
            <Setter Property="Margin" Value="0,12,0,0"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Hidden"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsAiSuggestionRunning}" Value="True">
                    <Setter Property="Width" Value="480"/>
                    <Setter Property="HorizontalAlignment" Value="Center"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Background="#F3F4F6">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="16,16,16,8"
                Style="{StaticResource MaintenanceCard}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="0">
                    <UniformGrid Margin="0"
                                 Columns="3"
                                 MaxWidth="640"
                                 HorizontalAlignment="Left">
                        <StackPanel>
                            <TextBlock Text="CSV 文件" Foreground="#667085"/>
                            <TextBlock Text="{Binding FileCountText}"
                                       Margin="0,4,0,0"
                                       FontSize="24"
                                       FontWeight="SemiBold"
                                       Foreground="#111827"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="数据锚点" Foreground="#667085"/>
                            <TextBlock Text="{Binding LatestDateText}"
                                       Margin="0,4,0,0"
                                       FontSize="24"
                                       FontWeight="SemiBold"
                                       Foreground="#111827"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="分析对象" Foreground="#667085"/>
                            <TextBlock Text="气缸 / 真空吸"
                                       Margin="0,4,0,0"
                                       FontSize="24"
                                       FontWeight="SemiBold"
                                       Foreground="#111827"/>
                        </StackPanel>
                    </UniformGrid>
                </StackPanel>

                <StackPanel Grid.Row="0"
                            Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="范围"
                               Margin="0,0,8,0"
                               VerticalAlignment="Center"
                               Foreground="#667085"/>
                    <ComboBox Width="110"
                              Height="34"
                              Margin="0,0,8,0"
                              ItemsSource="{Binding DateRangeOptions}"
                              SelectedItem="{Binding SelectedDateRangeMode, Mode=TwoWay}"
                              VerticalContentAlignment="Center"/>
                    <DatePicker Width="126"
                                Height="34"
                                Margin="0,0,6,0"
                                SelectedDate="{Binding CustomStartDate, Mode=TwoWay}"
                                Visibility="{Binding CustomRangeVisibility}"/>
                    <TextBlock Text="至"
                               Margin="0,0,6,0"
                               VerticalAlignment="Center"
                               Foreground="#667085"
                               Visibility="{Binding CustomRangeVisibility}"/>
                    <DatePicker Width="126"
                                Height="34"
                                Margin="0,0,12,0"
                                SelectedDate="{Binding CustomEndDate, Mode=TwoWay}"
                                Visibility="{Binding CustomRangeVisibility}"/>
                    <Button x:Name="BtnRefresh"
                            Content="重新分析"
                            VerticalAlignment="Center"
                            Style="{StaticResource PrimaryButton}"
                            Click="BtnRefresh_Click"/>
                </StackPanel>
                <TextBlock Grid.Row="1"
                           Grid.ColumnSpan="2"
                           Margin="0,10,0,0"
                           FontSize="12"
                           Foreground="#667085"
                           Text="{Binding RefreshStatusText}"/>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1"
                      Margin="16,8,16,16"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <Border Style="{StaticResource MaintenanceCard}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="280"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="14"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="14"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.ColumnSpan="3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="气缸数据趋势"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Foreground="#111827"/>
                            <ComboBox Grid.Column="2"
                                      Style="{StaticResource TrendSelectorComboBox}"
                                      ItemsSource="{Binding CylinderOptions}"
                                      SelectedItem="{Binding SelectedCylinder, Mode=TwoWay}"
                                      DisplayMemberPath="ComponentName"/>
                        </Grid>
                        <skia:SKElement x:Name="CylinderChart"
                                        Grid.Row="2"
                                        Grid.ColumnSpan="3"
                                        PaintSurface="CylinderChart_PaintSurface"
                                        MouseMove="CylinderChart_MouseMove"
                                        MouseLeave="CylinderChart_MouseLeave"/>

                        <Border Grid.Row="7"
                                Grid.ColumnSpan="3"
                                Style="{StaticResource AiSuggestionPanel}">
                            <StackPanel DataContext="{Binding SelectedCylinder}">
                                <Border Style="{StaticResource AiSuggestionBadge}">
                                    <TextBlock Text="{Binding AiSuggestionTitle}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               TextAlignment="Center"
                                               TextWrapping="NoWrap"
                                               FontSize="17"
                                               FontWeight="SemiBold"
                                               Foreground="#075985"/>
                                </Border>
                                <TextBlock Text="{Binding AiSuggestionFailureMessage}"
                                           Style="{StaticResource AiSuggestionFailureText}"/>
                                <ScrollViewer Style="{StaticResource AiSuggestionBodyScroll}">
                                    <TextBlock Text="{Binding AiSuggestionDisplayText}"
                                               Margin="0"
                                               Style="{StaticResource AiSuggestionText}"/>
                                </ScrollViewer>
                                <ProgressBar Value="{Binding AiSuggestionProgress}"
                                             Style="{StaticResource AiSuggestionProgressBar}"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Row="3"
                                Grid.Column="0"
                                Grid.ColumnSpan="3"
                                Margin="0,10,0,0"
                                Style="{StaticResource RiskSummaryBox}">
                            <StackPanel>
                                <TextBlock Text="最大风险"
                                           Style="{StaticResource RiskSummaryTitle}"/>
                                <TextBlock Text="{Binding CylinderSummary}"
                                           Style="{StaticResource RiskSummaryText}"/>
                            </StackPanel>
                        </Border>

                        <DataGrid Grid.Row="5"
                                  Grid.ColumnSpan="3"
                                  Style="{StaticResource MaintenanceDataGrid}"
                                  ItemsSource="{Binding CylinderStatuses}"
                                  MouseDoubleClick="CylinderStatusGrid_MouseDoubleClick"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  >
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="AI提示风险较大的气缸" Binding="{Binding ComponentName}" Width="1.6*" HeaderStyle="{StaticResource MaintenanceRiskColumnHeader}" ElementStyle="{StaticResource MaintenanceDataGridText}"/>
                                <DataGridTextColumn Header="来源" Binding="{Binding SourceNames}" Width="1.1*" ElementStyle="{StaticResource MaintenanceDataGridText}"/>
                                <DataGridTextColumn Header="样本" Binding="{Binding SampleCount}" Width="0.75*" ElementStyle="{StaticResource MaintenanceDataGridText}"/>
                                <DataGridTextColumn Header="原位均值" Binding="{Binding HomeAverageValue, StringFormat=0.###}" Width="1*" ElementStyle="{StaticResource MaintenanceDataGridText}"/>
                                <DataGridTextColumn Header="原位最大" Binding="{Binding HomeMaxValue, StringFormat=0.###}" Width="1*" ElementStyle="{StaticResource MaintenanceDataGridText}"/>
                                <DataGridTextColumn Header="原位最新" Binding="{Binding HomeLatestValue, StringFormat=0.###}" Width="1*" ElementStyle="{StaticResource MaintenanceDataGridText}"/>
                                <DataGridTextColumn Header="动位均值" Binding="{Binding WorkAverageValue, StringFormat=0.###}" Width="1*" ElementStyle="{StaticResource MaintenanceDataGridText}"/>
                                <DataGridTextColumn Header="动位最大" Binding="{Binding WorkMaxValue, StringFormat=0.###}" Width="1*" ElementStyle="{StaticResource MaintenanceDataGridText}"/>
                                <DataGridTextColumn Header="动位最新" Binding="{Binding WorkLatestValue, StringFormat=0.###}" Width="1*" ElementStyle="{StaticResource MaintenanceDataGridText}"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <Border Margin="0,16,0,0"
                        Style="{StaticResource MaintenanceCard}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="280"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="14"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="14"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.ColumnSpan="3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="吸嘴数据趋势"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Foreground="#111827"/>
                            <ComboBox Grid.Column="2"
                                      Style="{StaticResource TrendSelectorComboBox}"
                                      ItemsSource="{Binding VacuumOptions}"
                                      SelectedItem="{Binding SelectedVacuum, Mode=TwoWay}"
                                      DisplayMemberPath="ComponentName"/>
                        </Grid>
                        <skia:SKElement x:Name="VacuumChart"
                                        Grid.Row="2"
                                        Grid.ColumnSpan="3"
                                        PaintSurface="VacuumChart_PaintSurface"
                                        MouseMove="VacuumChart_MouseMove"
                                        MouseLeave="VacuumChart_MouseLeave"/>

                        <Border Grid.Row="7"
                                Grid.ColumnSpan="3"
                                Style="{StaticResource AiSuggestionPanel}">
                            <StackPanel DataContext="{Binding SelectedVacuum}">
                                <Border Style="{StaticResource AiSuggestionBadge}">
                                    <TextBlock Text="{Binding AiSuggestionTitle}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               TextAlignment="Center"
                                               TextWrapping="NoWrap"
                                               FontSize="17"
                                               FontWeight="SemiBold"
                                               Foreground="#075985"/>
                                </Border>
                                <TextBlock Text="{Binding AiSuggestionFailureMessage}"
                                           Style="{StaticResource AiSuggestionFailureText}"/>
                                <ScrollViewer Style="{StaticResource AiSuggestionBodyScroll}">
                                    <TextBlock Text="{Binding AiSuggestionDisplayText}"
                                               Margin="0"
                                               Style="{StaticResource AiSuggestionText}"/>
                                </ScrollViewer>
                                <ProgressBar Value="{Binding AiSuggestionProgress}"
                                             Style="{StaticResource AiSuggestionProgressBar}"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Row="3"
                                Grid.Column="0"
                                Grid.ColumnSpan="3"
                                Margin="0,10,0,0"
                                Style="{StaticResource RiskSummaryBox}">
                            <StackPanel>
                                <TextBlock Text="最大风险"
                                           Style="{StaticResource RiskSummaryTitle}"/>
                                <TextBlock Text="{Binding VacuumSummary}"
                                           Style="{StaticResource RiskSummaryText}"/>
                            </StackPanel>
                        </Border>

                        <DataGrid Grid.Row="5"
                                  Grid.ColumnSpan="3"
                                  Style="{StaticResource MaintenanceDataGrid}"
                                  ItemsSource="{Binding VacuumStatuses}"
                                  MouseDoubleClick="VacuumStatusGrid_MouseDoubleClick"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  >
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="AI提示风险较大的吸嘴" Binding="{Binding ComponentName}" Width="1.7*" HeaderStyle="{StaticResource MaintenanceRiskColumnHeader}" ElementStyle="{StaticResource MaintenanceDataGridText}"/>
                                <DataGridTextColumn Header="来源" Binding="{Binding SourceNames}" Width="1.1*" ElementStyle="{StaticResource MaintenanceDataGridText}"/>
                                <DataGridTextColumn Header="样本" Binding="{Binding SampleCount}" Width="0.8*" ElementStyle="{StaticResource MaintenanceDataGridText}"/>
                                <DataGridTextColumn Header="平均" Binding="{Binding AverageValue, StringFormat=0.###}" Width="1*" ElementStyle="{StaticResource MaintenanceDataGridText}"/>
                                <DataGridTextColumn Header="最大" Binding="{Binding MaxValue, StringFormat=0.###}" Width="1*" ElementStyle="{StaticResource MaintenanceDataGridText}"/>
                                <DataGridTextColumn Header="最新" Binding="{Binding LatestValue, StringFormat=0.###}" Width="1*" ElementStyle="{StaticResource MaintenanceDataGridText}"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
